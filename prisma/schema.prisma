generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LlmEvent {
  id                   String   @id @default(uuid())
  ts                   DateTime @default(now())
  provider             String
  model                String
  surface              String?
  sessionId            String?
  userId               String?  @map("user_id") @db.VarChar(255)
  spanId               String?  @map("span_id")
  parentSpanId         String?  @map("parent_span_id")
  project              String?
  inputTokens          Int
  outputTokens         Int
  reasoningTokens      Int      @default(0)
  cachedTokens         Int      @default(0)
  cacheCreationTokens  Int      @default(0)
  costUsd              Decimal  @db.Decimal(10, 6)
  latencyMs            Int?
  region               String?
  status               String   @default("ok")
  contentType          String?
  qualityScore         Decimal? @db.Decimal(4, 2)
  billingUnit          String   @default("tokens") @map("billing_unit")
  rawPayload           Json
  eventHash            String?  @unique @map("event_hash")
  promptHash           String?  @map("prompt_hash") @db.VarChar(16)

  @@index([ts(sort: Desc)])
  @@index([provider, ts(sort: Desc)])
  @@index([sessionId, ts])
  @@index([userId])
  @@index([parentSpanId])
  @@index([project])
  @@index([promptHash])
  @@map("llm_events")
}

model RegisteredService {
  id               String   @id @default(uuid())
  provider         String   @unique
  label            String
  category         String   @default("llm")
  billingPlan      String   @default("api")   @map("billing_plan")
  monthlyBudgetUsd Float    @default(0)        @map("monthly_budget_usd")
  addedAt          DateTime @default(now())

  @@map("registered_services")
}

model Annotation {
  id       String   @id @default(uuid())
  ts       DateTime
  type     String
  title    String
  detail   String?
  impact   String?
  severity String
  score    Int?
  traceId  String?  @map("trace_id")

  @@index([ts(sort: Desc)])
  @@index([traceId])
  @@map("annotations")
}

model ArchiveRun {
  id              String    @id @db.Uuid
  startedAt       DateTime  @map("started_at") @db.Timestamptz
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz
  status          String    @default("running")
  cutoffDays      Int       @map("cutoff_days")
  hotCount        Int       @default(0) @map("hot_count")
  warmCount       Int       @default(0) @map("warm_count")
  coldCount       Int       @default(0) @map("cold_count")
  archiveCount    Int       @default(0) @map("archive_count")
  rowsRolledUp    Int       @default(0) @map("rows_rolled_up")
  rowsDeleted     Int       @default(0) @map("rows_deleted")
  rollupDaysSpan  Int       @default(0) @map("rollup_days_span")
  exportPath      String?   @map("export_path")
  errorMessage    String?   @map("error_message")

  @@map("archive_runs")
}

model LlmDailyRollup {
  id                  String   @id @db.Uuid
  day                 DateTime @db.Date
  provider            String
  model               String
  project             String?
  surface             String?
  calls               Int      @default(0)
  costUsd             Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  inputTokens         BigInt   @default(0) @map("input_tokens")
  outputTokens        BigInt   @default(0) @map("output_tokens")
  cachedTokens        BigInt   @default(0) @map("cached_tokens")
  cacheCreationTokens BigInt   @default(0) @map("cache_creation_tokens")
  reasoningTokens     BigInt   @default(0) @map("reasoning_tokens")
  errorCount          Int      @default(0) @map("error_count")
  avgLatencyMs        Float?   @map("avg_latency_ms")
  p50Ms               Float?   @map("p50_ms")
  p95Ms               Float?   @map("p95_ms")
  p99Ms               Float?   @map("p99_ms")
  cacheHits           Int      @default(0) @map("cache_hits")
  cacheAttempts       Int      @default(0) @map("cache_attempts")
  archivedRawCount    Int      @default(0) @map("archived_raw_count")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("llm_daily_rollups")
}

model SessionLabel {
  sessionId String   @id
  label     String
  updatedAt DateTime @updatedAt

  @@map("session_labels")
}

model AlertRule {
  id         String   @id
  name       String
  metric     String
  lookback   String
  operator   String
  threshold  Decimal  @db.Decimal(12, 4)
  enabled    Boolean  @default(true)
  webhookUrl String?  @map("webhook_url")
  createdAt  DateTime @default(now())

  @@map("alert_rules")
}

model Budget {
  id        String   @id @default(uuid())
  project   String?
  provider  String?
  limitUsd  Decimal  @db.Decimal(12, 4)
  period    String   @default("30D")
  alertPct  Int      @default(80)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("budgets")
}

model EvalDataset {
  id        String            @id @default(uuid())
  name      String
  createdAt DateTime          @default(now()) @map("created_at")
  items     EvalDatasetItem[]

  @@map("eval_datasets")
}

model EvalDatasetItem {
  id        String      @id @default(uuid())
  datasetId String      @map("dataset_id")
  eventId   String      @map("event_id")
  note      String?
  addedAt   DateTime    @default(now()) @map("added_at")
  dataset   EvalDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, eventId])
  @@map("eval_dataset_items")
}
